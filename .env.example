ANTHROPIC_API_KEY=sk-ant-...

# Optional: shared-secret HTTP Basic Auth.
# If both are set, every request requires these credentials.
# Leave unset for local dev; set both in production.
# BASIC_AUTH_USER=team
# BASIC_AUTH_PASS=change-me

# Optional overrides
# PORT=3000
# MODEL=claude-opus-4-7

# Refero (Reference Finder agent). Required for the Reference Finder agent;
# omit and the agent returns a clear 503 with no other side effects.
# REFERO_TOKEN=mcp-...
# REFERO_MCP_URL=https://api.refero.design/v1/mcp
